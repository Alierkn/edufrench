// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

// ==========================================
// NEXTAUTH ŞEMALARI
// ==========================================
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// KULLANICI / ÖĞRENCİ ŞEMASI (NextAuth Destekli)
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hashed password
  role          UserRole  @default(USER)
  /// Arkadaş FOMO e-postaları için açık rıza (varsayılan kapalı)
  emailFomoOptIn Boolean @default(false)
  
  // Custom EduFrancais fields
  school        String?   // Saint Joseph vs.
  grade         String?   // 10. Sınıf vb.
  weakness      String?   // En çok zorlandığı alan
  source        String?   // Bizi nereden duydu
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relational fields
  accounts       Account[]
  sessions       Session[]
  progress       UserProgress[]
  submissions    Submission[]
  studySessions  StudySession[]
}

// ==========================================
// AKADEMİK MODÜLLER VE EGZERSİZLER
// ==========================================
model Module {
  id          String   @id @default(uuid())
  title       String   // örn: "Çevre Kirliliği" 
  type        String   // CE, CO, PE, PO, Grammaire, Vocabulaire
  level       String   // A2, B1, B2
  description String?  // Modül tüyoları veya yönergeleri
  /// Hedef sınıflar: ["9","10"] veya null = tüm sınıflar
  targetGrades  Json?
  /// Hedef okullar: ["sjb","sb"] veya null = tüm okullar
  targetSchools Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  exercises      Exercise[]
  studySessions  StudySession[]
}

model Exercise {
  id          String   @id @default(uuid())
  moduleId    String
  title       String   
  content     String   // Okuma metni, dinleme transcripti veya görev prompt'u
  mediaUrl    String?  // Ses dosyası (CO için) veya görsel
  type        String   // MCQ (Çoktan seçmeli), FILL (Boşluk doldurma), TEXT, RECORDING
  createdAt   DateTime @default(now())

  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  options     ExerciseOption[]
  submissions Submission[]
}

model ExerciseOption {
  id          String   @id @default(uuid())
  exerciseId  String
  text        String   // Örneğin şık metni "Le droit"
  isCorrect   Boolean  // Doğru cevap mı?
  
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// ==========================================
// ÖĞRENCİ İLERLEME VE FOMO BİLDİRİM ŞEMASI
// ==========================================
model UserProgress {
  id             String   @id @default(uuid())
  userId         String
  lastModuleType String   // En son çalışılan modül tipi 
  weaknesses     String   // JSON array of strings
  totalScore     Int      @default(0)
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudySession {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  startTime DateTime @default(now())
  endTime   DateTime?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

// ==========================================
// SUBMISSIONS (ÖĞRETMEN / AI FEEDBACK DÖNGÜSÜ)
// ==========================================
model Submission {
  id          String   @id @default(uuid())
  userId      String
  /// PO veya harici modüllerde egzersiz yoksa null (ElevenLabs / blob sonrası genişletilebilir)
  exerciseId  String?
  content     String?  // PE metni veya PO meta JSON
  mediaUrl    String?  // PO ses URL (ileride blob)
  score       Float?   // Öğretmen/AI puanı
  feedback    String?  // Geri bildirim JSON formatında veya Düz metin
  status      String   @default("PENDING") // PENDING, REVIEWED
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
}
