# --- Neon PostgreSQL ---
# Pooled (uygulama — Vercel / Next.js): Dashboard → Connection string → "Pooled"
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct (Prisma migrate / db push): aynı projede "Direct" veya pooler olmayan host
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# Kanonik site adresi (metadata, OG URL, sitemap). Üretimde zorunlu tutun.
# Örnek: https://www.edufrancais.com
NEXT_PUBLIC_SITE_URL=

# NextAuth (Vercel’de Production + Preview için tanımlayın; yoksa runtime’da oturum hata verir)
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# İlk admin: kayıtlı kullanıcı e-postası (seed çalışınca role=ADMIN)
ADMIN_BOOTSTRAP_EMAIL=

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# İsteğe bağlı
OPENAI_API_KEY=
RESEND_API_KEY=
